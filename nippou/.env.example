# nippou.sh 設定ファイル
# コピーして .env として使用: cp .env.example .env && chmod 600 .env

# GitHub ユーザー名 (未設定の場合 gh auth 済みユーザーを自動取得)
# GH_AUTHOR="your-github-username"

# レポート出力先ディレクトリ (未設定の場合はスクリプトと同階層の logs/)
# REPORT_DIR="$HOME/Documents/nippou"

# zsh 履歴ファイルのパス
# HIST_FILE="$HOME/.zsh_history"

# Slack API トークン (設定すると Slack メッセージも収集)
# SLACK_TOKEN="xoxp-xxxx-xxxx-xxxx"
